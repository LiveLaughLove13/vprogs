# Kaspa RPC Configuration
# URL of your Kaspa node (default: ws://127.0.0.1:17110)
KASPA_RPC_URL=ws://127.0.0.1:17110

# Wallet Configuration
# Your private key in hex format (64 characters = 32 bytes)
# WARNING: Never commit your actual private key to version control!
# Generate a test key or use a secure key management system
PRIVATE_KEY=your_64_character_hex_private_key_here

# Address Configuration
# Your Kaspa address (the address that will send the transaction)
FROM_ADDRESS=kaspa:your_sending_address_here

# Recipient address (where the transaction will be sent)
TO_ADDRESS=kaspa:recipient_address_here

# Transaction Amount
# Amount in sompi (1 KAS = 100,000,000 sompi)
# Example: 1000000 = 0.001 KAS
AMOUNT=1000000
